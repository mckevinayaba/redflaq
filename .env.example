# ─── Frontend (Vite) ────────────────────────────────────────────────────────
# Supabase project URL and anon/publishable key — safe to expose in the browser
VITE_SUPABASE_URL="https://<project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="eyJ..."   # anon key from Supabase dashboard → Settings → API

# ─── Supabase Edge Functions ─────────────────────────────────────────────────
# These are injected automatically by the Supabase runtime; do NOT set them manually
# SUPABASE_URL=                          # auto-injected
# SUPABASE_SERVICE_ROLE_KEY=             # auto-injected

# ─── Yoco (payment provider) ─────────────────────────────────────────────────
YOCO_SECRET_KEY="sk_..."                 # Yoco dashboard → Developers → Secret key
YOCO_WEBHOOK_SECRET="whsec_..."         # Yoco dashboard → Developers → Webhook secret

# ─── Resend (transactional email) ────────────────────────────────────────────
RESEND_API_KEY="re_..."                  # resend.com → API Keys

# ─── WhatsApp Business API ───────────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN="EAA..."           # Meta for Developers → App → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID="1234..."      # Meta for Developers → WhatsApp → Phone Numbers
WHATSAPP_VERIFY_TOKEN="<random-string>" # Arbitrary string you choose; set same in Meta webhook config

# ─── Lovable auth-email-hook ─────────────────────────────────────────────────
LOVABLE_API_KEY="..."                    # Provided by Lovable for the auth email hook
LOVABLE_SEND_URL="https://..."          # Lovable email send endpoint URL

# ─── Data import / enrichment ────────────────────────────────────────────────
OPENSANCTIONS_API_KEY="..."             # opensanctions.org → Account → API key
FIRECRAWL_API_KEY="fc-..."             # firecrawl.dev → API keys
